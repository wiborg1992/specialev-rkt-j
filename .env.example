# ── Anthropic ──────────────────────────────────────────────
# Påkrævet: API-nøgle til Claude (bruges af server.js og server.py)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Server ─────────────────────────────────────────────────
PORT=3000

# ── Stitch MCP ─────────────────────────────────────────────
# API-nøgle til Google Stitch (UI-prototyping via MCP)
# Konfigureret i .mcp.json – sæt her hvis du foretrækker env-variabel
STITCH_API_KEY=your-stitch-api-key-here
